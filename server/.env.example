# ============================================================
# 数境空间官网后端 环境变量模板（占位，可入库，严禁填真实密钥）
# 真实值写入同目录 .env（已 .gitignore，不入库）
# ============================================================

# —— 运行环境 ——
NODE_ENV=development
PORT=4000

# —— 数据库（本地指向 deploy/docker-compose.dev.yml 起的 PostgreSQL）——
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shujing_dev?schema=public

# —— CORS 允许来源（逗号分隔；5173=当前 Vite 原型，3000=未来 Next.js）——
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# —— Swagger 文档开关（生产可关闭）——
SWAGGER_ENABLED=true

# ============================================================
# 以下为后续模块占位字段：本步脚手架不使用，先登记避免遗漏
# ============================================================

# —— JWT 鉴权（第 4 步 认证模块）——
# 【生产必读】NODE_ENV=production 时后端启动会强校验 JWT_ACCESS_SECRET：
#   - 长度必须 ≥ 32 字符
#   - 不得使用本占位值，也不得包含 dev_only / change_in_production / replace_me 等开发占位词
#   生成随机强密钥示例：openssl rand -base64 48
#   下方 replace_me_access 仅为占位，生产使用会被拒绝启动。
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# —— 阿里云 OSS / OSS 兼容对象存储（第 6 步 上传模块）——
# STORAGE_DRIVER：
#   - oss            走 ali-oss SDK
#   - oss-compatible 走 S3 兼容 SDK
# 阿里云 OSS（推荐）：
#   - OSS_REGION=oss-cn-shenzhen
#   - OSS_FORCE_PATH_STYLE=false
#   - OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
#   - OSS_PUBLIC_BASE=https://你的 bucket 公网域名、CNAME 或 CDN 域名
# 注意：
#   - OSS_PUBLIC_BASE 只用于拼接公开访问 URL，不参与 SDK endpoint 签名
#   - 真实上传仍需在本地 .env 填写真实值，并在对象存储侧配置浏览器 PUT 所需 CORS
STORAGE_DRIVER=oss
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=shujing-dev
OSS_REGION=oss-cn-shenzhen
OSS_ENDPOINT=
OSS_FORCE_PATH_STYLE=false
OSS_PUBLIC_BASE=
OSS_PRESIGN_EXPIRES=900

# —— 上传限制 ——
MAX_MODEL_SIZE_MB=500
MAX_COVER_SIZE_MB=5

# —— viewerUrl 域名白名单（上线前安全修复 2D）——
# 用途：模型「外链发布」（POST /api/models 仅传 viewerUrl）入库前，校验链接 hostname 是否在允许列表内，
#       防止任意 https 外链被作为 iframe Viewer 内嵌。仅作用于外链发布，不影响对象存储上传发布与历史数据读取。
# 规则：
#   - 多个域名用英文逗号分隔；
#   - 只写 host，不要写完整 URL（写 sketchfab.com，不要写 https://sketchfab.com/...）；
#   - 支持精确主机（sketchfab.com）与通配子域（*.xgrids.cloud，命中裸域及任意子域）；
#   - 留空时回退到代码内默认安全列表：sketchfab.com,www.sketchfab.com,lcc-viewer.xgrids.cloud；
#   - 未来新增 Viewer 服务域名时，需在此处同步追加。
VIEWER_URL_ALLOWED_HOSTS=sketchfab.com,www.sketchfab.com,lcc-viewer.xgrids.cloud

# —— 短信验证码服务（第 4 步）——
SMS_ACCESS_KEY=
SMS_SECRET=
SMS_SIGN=
SMS_TEMPLATE=

# —— Redis（二期：限流/验证码缓存）——
REDIS_URL=redis://localhost:6379

# —— 管理员初始化（pnpm admin:init 使用；真实值仅运行时注入，严禁写入仓库）——
# 用途：不依赖 Admin 前端，通过脚本创建 / 提升生产管理员账号。
#   - ADMIN_EMAIL       管理员登录邮箱（唯一标识，必填）
#   - ADMIN_PASSWORD    管理员明文密码（脚本内 bcrypt 哈希后入库；必填；长度 ≥ 12，禁用常见弱密码）
#   - ADMIN_NICKNAME    可选，默认取邮箱 @ 前缀
#   - ADMIN_FORCE_RESET 可选，=true 时对已存在用户强制重置密码（默认不覆盖）
# 注意：本模板不写真实密码；运行时用环境变量注入，例如：
#   $env:ADMIN_EMAIL="ops@your-domain.com"; $env:ADMIN_PASSWORD="<强密码>"; pnpm admin:init
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NICKNAME=
ADMIN_FORCE_RESET=false
