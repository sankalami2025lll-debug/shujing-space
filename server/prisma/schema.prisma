// 数境空间官网 Prisma Schema
//
// 本文件为「开发顺序第 3 步：数据库建模与种子」的数据模型定义。
// 依据：docs/backend-architecture-plan.md 第四节（共 10 张表）。
//
// 红线：
// - 数据库只存文件 URL / R2 object key / 业务信息，不存任何二进制。
// - 模型文件、封面图、视频实体一律落 Cloudflare R2；本表只记录可访问 URL 与 r2_key。
// - 枚举一律用 Prisma enum（角色 / 状态 / 可见性 / viewerType / 文件类型 / 验证码场景）。
//
// 字段映射（前端 communityData.ts → 本 schema）：
// - color / pattern 为纯前端卡片视觉效果，不属于业务数据，故不入库。
// - views("2.1k") → models.viewsCount(Int)；time("3天前") → models.createdAt(Timestamptz)，由 seed 清洗。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================== 枚举定义 ==============================

// 系统权限角色：普通用户 / 管理员
enum UserRole {
  user
  admin
}

// 账号状态：启用 / 禁用
enum UserStatus {
  active
  disabled
}

// 模型查看器来源类型：iframe 内嵌 / Sketchfab / 原生查看器 / 无在线查看器
enum ViewerType {
  iframe
  sketchfab
  native
  none
}

// 模型可见性：公开 / 仅自己 / 审核后公开
enum ModelVisibility {
  public
  private
  review
}

// 模型审核状态：草稿 / 待审核 / 已发布 / 已驳回
enum ModelStatus {
  draft
  pending
  published
  rejected
}

// 模型后台处理状态：文件已上传 / 解析中 / 可浏览 / 解析失败
enum ModelProcessingStatus {
  uploaded
  processing
  ready
  failed
}

// 上传任务总体状态：排队 / 运行中 / 后台处理中 / 已发布 / 失败 / 已取消 / 已中断
enum UploadTaskStatus {
  queued
  running
  processing
  published
  failed
  canceled
  interrupted
}

// 上传任务阶段：对齐前端任务卡恢复所需的细粒度阶段
enum UploadTaskStage {
  queued
  presigning_model
  uploading_model
  callbacking_model
  presigning_cover
  uploading_cover
  callbacking_cover
  creating_model
  processing
  published
  failed
  canceled
  interrupted
}

// multipart 会话状态：已初始化 / 上传中 / 已暂停 / 失败 / 已完成 / 已中止
enum UploadMultipartStatus {
  initiated
  uploading
  paused
  failed
  completed
  aborted
}

// 上传文件用途：模型文件 / 封面图 / 视频
enum FileKind {
  model
  cover
  video
}

// 训练数据服务申请状态流转
enum TrainingStatus {
  submitted
  contacted
  evaluating
  quoted
  closed
}

// 联系线索状态流转
enum LeadStatus {
  new
  contacted
  qualified
  quoted
  won
  lost
}

// 验证码用途场景：注册 / 登录 / 找回密码
enum VerificationScene {
  register
  login
  reset
}

// ============================== 数据表 ==============================

/// users：用户 / 账号表
model User {
  id           BigInt     @id @default(autoincrement())
  phone        String?    @unique @db.VarChar(20) // 手机号
  email        String?    @unique @db.VarChar(120) // 邮箱
  passwordHash String?    @map("password_hash") @db.VarChar(255) // bcrypt 哈希；验证码注册可空
  nickname     String     @db.VarChar(60) // 显示名
  company      String?    @db.VarChar(120) // 公司
  roleType     String?    @map("role_type") @db.VarChar(40) // 注册表单填写的角色/需求类型
  role         UserRole   @default(user) // 系统权限
  avatarUrl    String?    @map("avatar_url") @db.VarChar(255) // 头像（R2 URL）
  status       UserStatus @default(active) // 账号状态
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  // 关系
  models               Model[]
  modelFiles           ModelFile[]
  uploadTasks          UploadTask[]
  multipartSessions    UploadMultipartSession[]
  favorites            Favorite[]
  likes                Like[]
  trainingApplications TrainingApplication[]

  @@map("users")
}

/// categories：模型分类表（后台分类管理 + 前端筛选）
model Category {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique @db.VarChar(40) // 实景三维 / BIM 模型 / 构件级模型 / 具身智能机器人训练场景
  slug      String   @unique @db.VarChar(40) // 英文标识
  sort      Int      @default(0) // 排序权重
  isActive  Boolean  @default(true) @map("is_active") // 是否启用
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  models Model[]

  @@map("categories")
}

/// models：模型主表（核心）
model Model {
  id                  BigInt                @id @default(autoincrement())
  userId              BigInt                @map("user_id") // 发布者
  categoryId          BigInt?               @map("category_id") // 分类
  type                String                @db.VarChar(40) // 冗余类型名（与分类一致，兼容原型展示）
  title               String                @db.VarChar(120) // 标题
  tags                Json                  @default("[]") // 标签数组
  scenes              Json                  @default("[]") // 应用场景多选
  description         String                @default("") @db.Text // 简介
  coverUrl            String                @default("") @map("cover_url") @db.VarChar(255) // 封面图 R2 URL（不存二进制）
  modelUrl            String?               @map("model_url") @db.VarChar(255) // 模型资源 / 外部 Viewer 地址 → 前端 viewerUrl
  viewerType          ViewerType            @default(none) @map("viewer_type") // 查看器来源
  allowIframe         Boolean               @default(true) @map("allow_iframe") // 是否允许 iframe 内嵌（兜底用）
  fileFormat          String?               @map("file_format") @db.VarChar(20) // glb/gltf/ifc/3dtiles/点云
  viewsCount          Int                   @default(0) @map("views_count") // 浏览量
  likesCount          Int                   @default(0) @map("likes_count") // 点赞量
  favoritesCount      Int                   @default(0) @map("favorites_count") // 收藏量
  visibility          ModelVisibility       @default(public) // 可见性
  status              ModelStatus           @default(draft) // 审核状态
  processingStatus    ModelProcessingStatus @default(ready) @map("processing_status") // 后台处理状态：uploaded/processing/ready/failed
  processingError     String?               @map("processing_error") @db.Text // 后台处理失败原因
  processedAt         DateTime?             @map("processed_at") @db.Timestamptz(6) // 处理完成时间（ready/failed）
  launchViewJson      Json?                 @map("launch_view_json") // 模型启动视图快照（仅保存可序列化视图数据）
  launchViewUpdatedAt DateTime?             @map("launch_view_updated_at") @db.Timestamptz(6) // 启动视图最近更新时间
  launchViewUpdatedBy BigInt?               @map("launch_view_updated_by") // 最近保存启动视图的用户 id
  rejectReason        String?               @map("reject_reason") @db.Text // 驳回原因（后台审核）
  deletedAt           DateTime?             @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  deletedBy           BigInt?               @map("deleted_by") // 执行删除的用户 id（普通用户或管理员）
  deleteReason        String?               @map("delete_reason") @db.Text // 删除原因（管理员可填）
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  // 关系
  user       User        @relation(fields: [userId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  uploadTask UploadTask? @relation("UploadTaskModel")
  favorites  Favorite[]
  likes      Like[]

  @@index([type, status])
  @@index([status, createdAt])
  @@index([processingStatus, createdAt])
  @@index([userId])
  @@map("models")
}

/// model_files：上传文件登记表（指向 R2，只存 URL / object key，不存二进制）
model ModelFile {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id") // 上传者
  kind         FileKind // 文件用途：model / cover / video
  originalName String   @map("original_name") @db.VarChar(255) // 原始文件名
  r2Key        String   @map("r2_key") @db.VarChar(255) // R2 对象 key
  url          String   @db.VarChar(255) // 可访问 URL（R2 公共域 / CDN 域）
  size         BigInt // 字节
  mime         String   @db.VarChar(80) // MIME 类型
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User                     @relation(fields: [userId], references: [id])
  modelUploadTasks  UploadTask[]             @relation("UploadTaskModelFile")
  coverUploadTasks  UploadTask[]             @relation("UploadTaskCoverFile")
  multipartSessions UploadMultipartSession[] @relation("UploadMultipartSessionModelFile")

  @@index([userId])
  @@map("model_files")
}

/// upload_tasks：上传任务编排表（只持久化任务状态，不承诺真正断点续传）
model UploadTask {
  id                    BigInt           @id @default(autoincrement())
  userId                BigInt           @map("user_id")
  clientToken           String?          @map("client_token") @db.VarChar(64)
  title                 String           @db.VarChar(120)
  type                  String           @db.VarChar(40)
  scenesJson            Json             @default("[]") @map("scenes_json")
  description           String           @default("") @db.Text
  visibility            ModelVisibility
  viewerUrl             String?          @map("viewer_url") @db.VarChar(255)
  plannedModelName      String?          @map("planned_model_name") @db.VarChar(255)
  plannedModelSize      BigInt?          @map("planned_model_size")
  plannedModelMime      String?          @map("planned_model_mime") @db.VarChar(80)
  plannedCoverName      String?          @map("planned_cover_name") @db.VarChar(255)
  plannedCoverSize      BigInt?          @map("planned_cover_size")
  plannedCoverMime      String?          @map("planned_cover_mime") @db.VarChar(80)
  status                UploadTaskStatus @default(queued)
  stage                 UploadTaskStage  @default(queued)
  currentModelObjectKey String?          @map("current_model_object_key") @db.VarChar(255)
  currentCoverObjectKey String?          @map("current_cover_object_key") @db.VarChar(255)
  modelFileId           BigInt?          @map("model_file_id")
  coverFileId           BigInt?          @map("cover_file_id")
  modelId               BigInt?          @unique @map("model_id")
  attemptCount          Int              @default(0) @map("attempt_count")
  lastErrorStage        UploadTaskStage? @map("last_error_stage")
  lastErrorCode         String?          @map("last_error_code") @db.VarChar(64)
  lastErrorMessage      String?          @map("last_error_message") @db.Text
  startedAt             DateTime?        @map("started_at") @db.Timestamptz(6)
  lastHeartbeatAt       DateTime?        @map("last_heartbeat_at") @db.Timestamptz(6)
  interruptedAt         DateTime?        @map("interrupted_at") @db.Timestamptz(6)
  canceledAt            DateTime?        @map("canceled_at") @db.Timestamptz(6)
  publishedAt           DateTime?        @map("published_at") @db.Timestamptz(6)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User                     @relation(fields: [userId], references: [id])
  modelFile         ModelFile?               @relation("UploadTaskModelFile", fields: [modelFileId], references: [id])
  coverFile         ModelFile?               @relation("UploadTaskCoverFile", fields: [coverFileId], references: [id])
  model             Model?                   @relation("UploadTaskModel", fields: [modelId], references: [id])
  multipartSessions UploadMultipartSession[]

  @@unique([userId, clientToken])
  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
  @@index([status, updatedAt])
  @@map("upload_tasks")
}

/// upload_multipart_sessions：multipart 上传会话表（支持真正分片续传）
model UploadMultipartSession {
  id                  BigInt                @id @default(autoincrement())
  uploadTaskId        BigInt                @map("upload_task_id")
  userId              BigInt                @map("user_id")
  kind                FileKind
  objectKey           String                @map("object_key") @db.VarChar(255)
  ossUploadId         String                @unique @map("oss_upload_id") @db.VarChar(255)
  originalName        String                @map("original_name") @db.VarChar(255)
  mime                String                @db.VarChar(80)
  fileSize            BigInt                @map("file_size")
  partSize            BigInt                @map("part_size")
  totalParts          Int                   @map("total_parts")
  fingerprintAlgo     String?               @map("fingerprint_algo") @db.VarChar(40)
  fingerprint         String?               @db.VarChar(255)
  fileLastModified    BigInt?               @map("file_last_modified")
  status              UploadMultipartStatus @default(initiated)
  uploadedBytes       BigInt                @default(0) @map("uploaded_bytes")
  completedPartsCount Int                   @default(0) @map("completed_parts_count")
  modelFileId         BigInt?               @map("model_file_id")
  lastErrorCode       String?               @map("last_error_code") @db.VarChar(64)
  lastErrorMessage    String?               @map("last_error_message") @db.Text
  isCurrent           Boolean               @default(true) @map("is_current")
  initiatedAt         DateTime              @default(now()) @map("initiated_at") @db.Timestamptz(6)
  lastActivityAt      DateTime?             @map("last_activity_at") @db.Timestamptz(6)
  completedAt         DateTime?             @map("completed_at") @db.Timestamptz(6)
  abortedAt           DateTime?             @map("aborted_at") @db.Timestamptz(6)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  uploadTask UploadTask            @relation(fields: [uploadTaskId], references: [id])
  user       User                  @relation(fields: [userId], references: [id])
  modelFile  ModelFile?            @relation("UploadMultipartSessionModelFile", fields: [modelFileId], references: [id])
  parts      UploadMultipartPart[]

  @@index([uploadTaskId, kind, createdAt])
  @@index([userId, status, updatedAt])
  @@map("upload_multipart_sessions")
}

/// upload_multipart_parts：multipart 分片表（只保存分片状态与 etag，不存二进制）
model UploadMultipartPart {
  id               BigInt    @id @default(autoincrement())
  sessionId        BigInt    @map("session_id")
  partNumber       Int       @map("part_number")
  byteStart        BigInt    @map("byte_start")
  byteEnd          BigInt    @map("byte_end")
  partSize         BigInt    @map("part_size")
  etag             String?   @db.VarChar(255)
  uploadedAt       DateTime? @map("uploaded_at") @db.Timestamptz(6)
  attemptCount     Int       @default(0) @map("attempt_count")
  lastErrorCode    String?   @map("last_error_code") @db.VarChar(64)
  lastErrorMessage String?   @map("last_error_message") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  session UploadMultipartSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, partNumber])
  @@index([sessionId, partNumber])
  @@map("upload_multipart_parts")
}

/// favorites：收藏表
model Favorite {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  modelId   BigInt   @map("model_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id])
  model Model @relation(fields: [modelId], references: [id])

  @@unique([userId, modelId]) // 防重复收藏
  @@map("favorites")
}

/// likes：点赞表
model Like {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  modelId   BigInt   @map("model_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id])
  model Model @relation(fields: [modelId], references: [id])

  @@unique([userId, modelId]) // 防重复点赞
  @@map("likes")
}

/// training_applications：具身智能机器人训练场景 数据服务申请表
model TrainingApplication {
  id          BigInt         @id @default(autoincrement())
  userId      BigInt?        @map("user_id") // 登录则记录
  contactName String         @map("contact_name") @db.VarChar(60) // 联系人
  contactWay  String         @map("contact_way") @db.VarChar(120) // 手机/微信
  company     String         @db.VarChar(120) // 公司
  robotType   String         @map("robot_type") @db.VarChar(40) // 机器人类型
  trainTasks  Json           @default("[]") @map("train_tasks") // 训练任务多选
  sceneDesc   String         @map("scene_desc") @db.Text // 场景需求描述
  status      TrainingStatus @default(submitted) // 申请状态
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@map("training_applications")
}

/// contact_leads：联系线索表
model ContactLead {
  id         BigInt     @id @default(autoincrement())
  name       String     @db.VarChar(60) // 姓名
  contactWay String     @map("contact_way") @db.VarChar(120) // 手机/微信
  company    String?    @db.VarChar(120) // 公司
  email      String?    @db.VarChar(120) // 邮箱
  scene      String?    @db.VarChar(40) // 应用场景
  dataTypes  Json       @default("[]") @map("data_types") // 数据类型多选
  stage      String?    @db.VarChar(40) // 项目阶段
  budget     String?    @db.VarChar(40) // 预算范围
  message    String     @default("") @db.Text // 需求描述
  status     LeadStatus @default(new) // 线索状态
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@map("contact_leads")
}

/// verification_codes：验证码表（无 Redis 时用表，二期迁 Redis）
model VerificationCode {
  id        BigInt            @id @default(autoincrement())
  target    String            @db.VarChar(120) // 手机号/邮箱
  scene     VerificationScene // 用途
  codeHash  String            @map("code_hash") @db.VarChar(255) // 验证码哈希
  expiresAt DateTime          @map("expires_at") @db.Timestamptz(6) // 过期时间
  used      Boolean           @default(false) // 是否已用
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6) // 60s 限频依据

  @@index([target, scene])
  @@map("verification_codes")
}

/// site_configs：全站配置表（Footer 联系方式、备案号等）
model SiteConfig {
  key       String   @id @db.VarChar(60) // phone / email / address / icp 等
  value     String   @db.Text // 配置值
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_configs")
}
