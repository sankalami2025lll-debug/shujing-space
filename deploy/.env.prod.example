# =============================================================================
# 数境空间（Shujing Space）生产环境变量模板
# 复制本文件为 .env.prod 后填入真实值，用于 docker-compose.prod.yml
# =============================================================================

# --- 通用 ---
NODE_ENV=production

# --- 数据库（PostgreSQL） ---
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=public

# --- 服务监听 / 文档 ---
# 后端实际读取 PORT；生产如不需要 Swagger，建议关闭
PORT=4000
SWAGGER_ENABLED=false

# --- JWT 密钥 ---
# 后端实际读取 JWT_ACCESS_SECRET / JWT_ACCESS_EXPIRES
JWT_ACCESS_SECRET=<随机 32 位以上密钥>
JWT_ACCESS_EXPIRES=7d

# --- 对象存储：阿里云 OSS（S3 兼容接入） ---
# 密钥说明：当前代码使用 OSS_ACCESS_KEY_ID / OSS_ACCESS_KEY_SECRET 读取
# 存储后端为阿里云 OSS，Bucket 端点与地域按实际配置填写
STORAGE_DRIVER=oss
OSS_ACCESS_KEY_ID=<你的 AccessKey ID>
OSS_ACCESS_KEY_SECRET=<你的 AccessKey Secret>
OSS_BUCKET=<Bucket 名称>
OSS_REGION=<地域，如 cn-shenzhen>
OSS_ENDPOINT=https://oss-<region>.aliyuncs.com
OSS_PUBLIC_BASE=https://<bucket>.oss-<region>.aliyuncs.com
OSS_FORCE_PATH_STYLE=false
OSS_PRESIGN_EXPIRES=3600

# --- 上传大小限制（单位 MB） ---
# 后端实际读取 MAX_MODEL_SIZE_MB / MAX_COVER_SIZE_MB
MAX_MODEL_SIZE_MB=500
MAX_COVER_SIZE_MB=5

# --- CORS（生产环境应限制为前端域名） ---
# 正式上线时填入前端域名，不要带 /api
CORS_ORIGIN=https://shujingspace.com

# --- Next.js 前端构建时 API 基址（build-time） ---
# 正式上线时填入完整后端 API 地址，必须带 /api
# 注：此变量需同时在 docker-compose.prod.yml 的 web.build.args 中传递
NEXT_PUBLIC_API_BASE_URL=https://shujingspace.com/api

# --- 外链 viewer 域名白名单 ---
# 为空时使用后端内置安全默认值；如需显式声明，可按 host 逗号分隔填写
VIEWER_URL_ALLOWED_HOSTS=<host1>,<host2>
