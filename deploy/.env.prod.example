# =========================
# Docker Compose / PostgreSQL
# =========================
POSTGRES_USER=replace_with_prod_db_user
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=replace_with_prod_db_name

# =========================
# Server runtime
# =========================
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://replace_with_prod_db_user:replace_with_strong_db_password@postgres:5432/replace_with_prod_db_name?schema=public
CORS_ORIGIN=https://你的正式域名
SWAGGER_ENABLED=false
JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES=2h

# =========================
# Object storage
# =========================
# 生产环境对象存储最终口径：阿里云 OSS
# STORAGE_DRIVER：
#   - oss            走 ali-oss SDK
#   - oss-compatible 走 S3 兼容 SDK
STORAGE_DRIVER=oss
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=shujingspace
OSS_REGION=oss-cn-shenzhen
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_FORCE_PATH_STYLE=false
OSS_PUBLIC_BASE=https://shujingspace.oss-cn-shenzhen.aliyuncs.com
OSS_PRESIGN_EXPIRES=900
MAX_MODEL_SIZE_MB=512
MAX_COVER_SIZE_MB=20
VIEWER_URL_ALLOWED_HOSTS=你的正式域名

# =========================
# Web runtime
# =========================
NEXT_PUBLIC_API_BASE_URL=/api

# =========================
# Optional services
# =========================
REDIS_URL=
SMS_ACCESS_KEY=
SMS_SECRET=
SMS_SIGN=
SMS_TEMPLATE=

# =========================
# Admin bootstrap
# 仅在首次初始化管理员时填写或临时注入
# 生产不建议执行 seed，请使用 pnpm admin:init
# =========================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password
ADMIN_NICKNAME=系统管理员
ADMIN_FORCE_RESET=false
